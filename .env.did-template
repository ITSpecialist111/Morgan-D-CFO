# ============================================================================
# D-ID HUMANOID AVATAR CONFIGURATION
# ============================================================================
# This section configures the separate D-ID humanoid avatar platform (Mia Elegant)
# with ElevenLabs voices for Mission Control fallback/redundancy.
#
# All values marked with [REQUIRED] must be provided before D-ID avatar will be available.
# Values marked with [OPTIONAL] have sensible defaults from the working baseline config.
# Values marked with [TUNE] can be customized after baseline validation.
#
# Configuration Load Order:
# 1. Set environment variables below
# 2. Restart the application
# 3. D-ID avatar will be available in Mission Control as a separate button
# 4. Switch to "Mia Elegant (D-ID)" from the avatar toggle dropdown
#
# ============================================================================

# ============================================================================
# REQUIRED: D-ID API CREDENTIALS
# ============================================================================
# Get these from your D-ID developer dashboard: https://www.d-id.com/

# [REQUIRED] Your D-ID API key for agent management
DID_API_KEY=

# [REQUIRED] Your D-ID client key for session authentication
DID_CLIENT_KEY=

# ============================================================================
# REQUIRED: D-ID AGENT AND PRESENTER CONFIGURATION
# ============================================================================
# These pins the specific agent instance and presenter model.
# Do not change unless you're switching to a different D-ID agent setup.

# [OPTIONAL] D-ID agent ID (default: v2_agt_vXoxDzYG - Mia Elegant low-cut)
# Replace if you have a different agent already configured in D-ID
DID_AGENT_ID=v2_agt_vXoxDzYG

# [OPTIONAL] Presenter ID name (default: Mia Elegant)
DID_PRESENTER_NAME=Mia Elegant

# [OPTIONAL] Presenter ID full identifier (default: Mia Elegant low-cut variant)
# Do not change unless you're using a different presenter model
DID_PRESENTER_ID=public_mia_elegant@avt_TJ0Tq5

# ============================================================================
# REQUIRED: ELEVENLABS VOICE CONFIGURATION
# ============================================================================
# D-ID uses ElevenLabs for voice synthesis. Configure these to enable speech.

# [REQUIRED] Your ElevenLabs API key
# Get from: https://elevenlabs.io/app/keys
ELEVENLABS_API_KEY=

# [OPTIONAL] Voice ID for the avatar (default: Friendly profile)
# Default uses the "Friendly" voice which matches the baseline config
# You can change this to any ElevenLabs voice ID to customize voice
# Available voice IDs and their characteristics are listed on ElevenLabs dashboard
ELEVENLABS_VOICE_ID=yV421IFuyZtM5nbmHxOl

# [OPTIONAL] ElevenLabs model ID (default: eleven_flash_v2_5)
# Controls voice quality and response speed
# Options: eleven_flash_v2_5 (fast, recommended), eleven_turbo_v2_5, eleven_monolingual_v1
ELEVENLABS_MODEL_ID=eleven_flash_v2_5

# [TUNE] Voice stability (0.0 - 1.0, default: unset = use ElevenLabs default)
# Higher values = more consistent voice, lower values = more variation
# Only set if you want to fine-tune voice consistency after baseline works
# ELEVENLABS_STABILITY=0.5

# [TUNE] Similarity boost (0.0 - 1.0, default: unset = use ElevenLabs default)
# Higher values = closer to original voice, lower values = more variation
# Only set after baseline validation to customize voice character
# ELEVENLABS_SIMILARITY_BOOST=0.75

# [TUNE] Voice style (default: unset)
# Style parameters for voice personality: 'conversational', 'professional', 'narrative', etc.
# Only set after baseline validation
# ELEVENLABS_STYLE=conversational

# ============================================================================
# REQUIRED: D-ID MODE CONFIGURATION
# ============================================================================
# Do not change these unless explicitly instructed.

# [OPTIONAL] Disable clips mode (default: false = clips disabled, use expressive agent)
# Keep as 'false' to use D-ID expressive agent mode (recommended)
DID_USE_CLIPS=false

# [OPTIONAL] Speech source (default: did = use D-ID speech synthesis)
# Keep as 'did' to use D-ID's integrated ElevenLabs voice
DID_SPEECH_SOURCE=did

# ============================================================================
# OPTIONAL: UI BACKGROUND CONFIGURATION
# ============================================================================
# URL for the background image behind the avatar in the browser viewport

# [OPTIONAL] Background image URL for avatar viewport
# Default is a generic background from the referenced repo
# Change to your own image URL for branded presentation
AVATAR_BACKGROUND_URL=https://raw.githubusercontent.com/ITSpecialist111/Aria-Avatar-Foundry-WorkIQ/main/background.jpg

# ============================================================================
# VERIFICATION CHECKLIST
# ============================================================================
# After setting environment variables above, run:
#
# 1. Restart the application
# 2. Navigate to Mission Control: /mission-control
# 3. Look for "Avatar:" dropdown in the top header
# 4. Select "Mia Elegant (D-ID)" to switch to the new avatar
# 5. If "Mia Elegant (D-ID)" is not available in dropdown:
#    - Check that DID_API_KEY and ELEVENLABS_API_KEY are set correctly
#    - Check application logs for errors
#    - Verify API keys are not expired in D-ID and ElevenLabs dashboards
# 6. Once available, click to switch
# 7. Open the avatar view at: /voice
# 8. Verify you see the humanoid Mia Elegant presenter
# 9. Send a test message to confirm voice works with ElevenLabs
#
# ============================================================================
# FALLBACK STRATEGY
# ============================================================================
# If D-ID avatar runs out of tokens or encounters errors:
# 1. Go back to Mission Control
# 2. Switch avatar to "Morgan (Standard)" using the dropdown
# 3. This will restore the standard Azure Speech Avatar as fallback
# 4. You can switch back to "Mia Elegant (D-ID)" once tokens are refreshed
#
# ============================================================================
