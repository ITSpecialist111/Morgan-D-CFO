{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "func",
			"label": "func: host start",
			"command": "host start",
			"problemMatcher": "$func-node-watch",
			"isBackground": true,
			"dependsOn": "npm watch (functions)",
			"options": {
				"cwd": "${workspaceFolder}/azure-function-trigger"
			}
		},
		{
			"type": "shell",
			"label": "npm build (functions)",
			"command": "npm run build",
			"dependsOn": "npm install (functions)",
			"problemMatcher": "$tsc",
			"options": {
				"cwd": "${workspaceFolder}/azure-function-trigger"
			}
		},
		{
			"type": "shell",
			"label": "npm watch (functions)",
			"command": "npm run watch",
			"dependsOn": "npm install (functions)",
			"problemMatcher": "$tsc-watch",
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"isBackground": true,
			"options": {
				"cwd": "${workspaceFolder}/azure-function-trigger"
			}
		},
		{
			"type": "shell",
			"label": "npm install (functions)",
			"command": "npm install",
			"options": {
				"cwd": "${workspaceFolder}/azure-function-trigger"
			}
		},
		{
			"type": "shell",
			"label": "npm prune (functions)",
			"command": "npm prune --production",
			"dependsOn": "npm build (functions)",
			"problemMatcher": [],
			"options": {
				"cwd": "${workspaceFolder}/azure-function-trigger"
			}
		},
		{
			"label": "check workspace output",
			"type": "shell",
			"command": "Get-Location; Write-Output \"task-ok\"; Get-ChildItem .deploy | Select-Object -Last 3 -ExpandProperty Name",
			"isBackground": false,
			"problemMatcher": [],
			"group": "none"
		},
		{
			"label": "deploy updated Morgan avatar UI",
			"type": "shell",
			"command": "pwsh",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"scripts/deploy-avatar-ui.ps1"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "deploy avatar UI script",
			"type": "shell",
			"command": "pwsh",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"scripts/deploy-avatar-ui.ps1"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "build Morgan after mission starfield",
			"type": "shell",
			"command": "npm run build",
			"isBackground": false,
			"problemMatcher": [
				"$tsc"
			],
			"group": "build"
		},
		{
			"label": "deploy mission starfield update",
			"type": "shell",
			"command": "pwsh",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"scripts/deploy-avatar-ui.ps1"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "build Morgan D-CFO Kanban",
			"type": "shell",
			"command": "npm run build",
			"isBackground": false,
			"problemMatcher": [
				"$tsc"
			],
			"group": "build"
		},
		{
			"label": "verify D-CFO Kanban generator",
			"type": "shell",
			"command": "@'\nconst m = require('./dist/mission/missionControl.js');\nconst b = m.getAutonomousKanbanBoard();\nconsole.log(JSON.stringify({ columns: b.columns.map((c) => [c.id, c.cards.length]), next: b.nextBestAction, total: b.metrics.total, ai: b.aiKanbanAgent.status }, null, 2));\n'@ | node",
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "deploy Morgan D-CFO Kanban",
			"type": "shell",
			"command": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/deploy-avatar-ui.ps1",
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "build Morgan Teams federation",
			"type": "shell",
			"command": "npm run build",
			"isBackground": false,
			"problemMatcher": [
				"$tsc"
			],
			"group": "build"
		},
		{
			"label": "verify Teams federation status function",
			"type": "shell",
			"command": "@'\nconst bridge = require('./dist/voice/acsBridge.js');\nconst status = bridge.getTeamsFederationCallingStatus();\nconsole.log(JSON.stringify({ configured: status.configured, hasCommand: status.federationAdminCommand.includes('Set-CsTeamsAcsFederationConfiguration'), videoStatus: status.videoPresence.status }, null, 2));\n'@ | node",
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "deploy Morgan Teams federation",
			"type": "shell",
			"command": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/deploy-avatar-ui.ps1",
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "verify production workday handoff",
			"type": "shell",
			"command": "pwsh",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"scripts/verify-production-workday.ps1"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		}
	]
}