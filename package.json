{
  "name": "synth-finance-agent",
  "version": "1.0.0",
  "description": "Morgan - autonomous CorpGen Digital CFO worker and enterprise showcase",
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "start": "node scripts/start-production.cjs",
    "build": "tsc && node scripts/copy-static.cjs",
    "dev": "nodemon",
    "clean": "rimraf dist",
    "foundry:prepare-hosted": "node scripts/prepare-foundry-hosted-agent-definition.cjs",
    "foundry:diagnose-hosted": "node scripts/diagnose-foundry-hosted-readiness.cjs",
    "env:from-cassidy": "node scripts/import-cassidy-env.cjs",
    "env:from-azure": "node scripts/import-azure-env.cjs",
    "azure:deploy": "node scripts/deploy-appservice-zip.cjs",
    "agent365:publish-m365": "powershell -ExecutionPolicy Bypass -File scripts/publish-m365-agent.ps1"
  },
  "dependencies": {
    "@azure/communication-call-automation": "^1.5.1",
    "@azure/communication-common": "^2.4.0",
    "@azure/communication-identity": "^1.3.1",
    "@azure/cosmos": "^4.2.0",
    "@azure/identity": "^4.13.0",
    "@azure/msal-node": "^5.1.5",
    "@microsoft/agents-a365-tooling": "^1.0.0",
    "@microsoft/agents-a365-tooling-extensions-openai": "^1.0.0",
    "@microsoft/agents-activity": "^1.5.1",
    "@microsoft/agents-hosting": "^1.5.2",
    "@modelcontextprotocol/sdk": "^1.25.2",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.9",
    "@types/ws": "^8.18.1",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "openai": "^6.29.0",
    "typescript": "^5.4.5",
    "ws": "^8.19.0",
    "zod": "^3.25.0"
  },
  "optionalDependencies": {
    "applicationinsights": "^3.14.0"
  },
  "devDependencies": {
    "nodemon": "*",
    "rimraf": "*",
    "ts-node": "*"
  }
}
