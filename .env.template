# ─────────────────────────────────────────────────────────────────────────────
# Morgan — CFO's Digital Finance Analyst
# Copy this file to .env and fill in the values before running locally.
# ─────────────────────────────────────────────────────────────────────────────

# Azure Bot / Entra App Registration (from Agent 365 setup)
MicrosoftAppId=<blueprint-id-from-a365-setup>
MicrosoftAppPassword=<client-secret-from-a365-setup>
MicrosoftAppTenantId=<your-entra-tenant-id>

# Runtime
NODE_ENV=production
PORT=3978

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_REALTIME_DEPLOYMENT=gpt-realtime-mini
AZURE_OPENAI_REALTIME_API_VERSION=2025-04-01-preview

# Microsoft Foundry project alignment (same project/region as Cassidy where possible)
FOUNDRY_PROJECT_ENDPOINT=https://<your-foundry-account>.services.ai.azure.com/api/projects/<project-name>
AZURE_CONTAINER_REGISTRY_NAME=<acr-name>
APPLICATIONINSIGHTS_CONNECTION_STRING=<InstrumentationKey=...;IngestionEndpoint=...>
APPLICATIONINSIGHTS_RESOURCE_ID=/subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.Insights/components/<app-insights-name>
LOG_ANALYTICS_WORKSPACE_ID=<workspace-id>
PURVIEW_AUDIT_ENABLED=true
PURVIEW_AUDIT_WORKSPACE_ID=<purview-or-log-analytics-workspace-id-for-audit-review>

# Cosmos DB (persistent conversation memory)
COSMOS_DB_ENDPOINT=https://your-cosmos.documents.azure.com:443/
COSMOS_DB_DATABASE=morgan-memory
COSMOS_DB_CONTAINER=conversations
COSMOS_DB_KEY=<optional-cosmos-key-if-managed-identity-rbac-is-not-used>

# Azure Storage / Table Storage (Cassidy-compatible persistence foundation)
AZURE_STORAGE_ACCOUNT=<storage-account-name>

# MCP Platform — Agent 365 WorkIQ MCP catalog (same endpoint Cassidy uses)
MCP_PLATFORM_ENDPOINT=https://agent365.svc.cloud.microsoft
MCP_PLATFORM_AUTHENTICATION_SCOPE=ea9ffc3e-8a23-4a7d-836d-234d7c7565c1/.default
MCP_TOOL_TIMEOUT_MS=45000
GRAPH_TIMEOUT_MS=10000
GRAPH_CACHE_TTL_MS=60000

# Optional Planner integration — fills in default Planner group/plan for Morgan tasks
PLANNER_GROUP_ID=<m365-group-id>
PLANNER_PLAN_ID=<planner-plan-id>

# Agent identity
AGENT_NAME=Morgan
AGENT_ROLE=Digital CFO
ORG_TIMEZONE=AEDT (UTC+11)

# Morgan's own Microsoft 365 mailbox/calendar identity (advertised so users can email or invite Morgan directly)
MORGAN_MAILBOX_UPN=morgan@<your-tenant>.onmicrosoft.com
MORGAN_MEETING_INVITE_EMAIL=morgan@<your-tenant>.onmicrosoft.com

# Finance workflow settings
FINANCE_TEAMS_CHANNEL_ID=<teams-channel-id-for-finance-reports>
CFO_EMAIL=<cfo-email-for-weekly-briefings>
CFO_TEAMS_USER_AAD_OID=<cfo-or-operator-entra-user-object-id-for-teams-calls>
WEEKLY_BRIEFING_ENABLED=true
SCHEDULED_SECRET=<generate-a-random-secret>
MORGAN_AGENT_URL=https://<morgan-app>.azurewebsites.net
WEBSITE_TIME_ZONE=<optional-function-app-timezone-for-9-to-5-schedules>
AUTONOMOUS_WORKDAY_ENABLED=true
AUTONOMOUS_WORKDAY_TIME_ZONE=Australia/Sydney
AUTONOMOUS_WORKDAY_START_HOUR=9
AUTONOMOUS_WORKDAY_END_HOUR=17
AUTONOMOUS_WORKDAY_INTERVAL_MINUTES=25
MORGAN_MISSION_STATE_FILE=/home/data/morgan/mission-control-records.json
WEBSITES_ENABLE_APP_SERVICE_STORAGE=true

# Morgan cost and value dashboard
MORGAN_COST_AZURE_CACHE_SECONDS=900
MORGAN_COST_AZURE_STALE_SECONDS=3600
MORGAN_VALUE_FINANCE_HOURLY_RATE=125
MORGAN_VALUE_HOURS_PER_COMPLETED_TASK=1.25

# Optional authenticated agent-to-agent handoff headers.
SUB_AGENT_BEARER_TOKEN=<optional-shared-bearer-token-for-sub-agent-calls>
SUB_AGENT_SHARED_SECRET=<optional-shared-secret-for-x-agent-secret>
CASSIDY_AGENT_BEARER_TOKEN=<optional-cassidy-specific-bearer-token>
CASSIDY_AGENT_SHARED_SECRET=<optional-cassidy-specific-shared-secret>
AI_KANBAN_AGENT_BEARER_TOKEN=<optional-ai-kanban-specific-bearer-token>
AI_KANBAN_AGENT_SHARED_SECRET=<optional-ai-kanban-specific-shared-secret>

# Mission Control / sub-agent swarm
CASSIDY_AGENT_ENDPOINT=https://<cassidy-app>.azurewebsites.net
AVATAR_AGENT_ENDPOINT=https://<avatar-app>.azurewebsites.net
AI_KANBAN_AGENT_ENDPOINT=https://<ai-kanban-app>.azurewebsites.net

# Avatar voice experience
VOICELIVE_ENDPOINT=https://<your-ai-services-resource>.cognitiveservices.azure.com/
VOICELIVE_MODEL=gpt-5
VOICE_ENABLED_DEFAULT=true
VOICE_NAME=en-US-Ava:DragonHDLatestNeural
SPEECH_REGION=australiaeast
AZURE_AI_SERVICES_ENDPOINT=https://<your-ai-services-resource>.cognitiveservices.azure.com/
AZURE_SPEECH_ENDPOINT=https://<your-speech-region>.api.cognitive.microsoft.com/
SPEECH_RESOURCE_ID=/subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.CognitiveServices/accounts/<speech-account>
SPEECH_RESOURCE_KEY=<optional-speech-key-or-use-managed-identity>
AVATAR_CHARACTER=meg
AVATAR_STYLE=business
AVATAR_DISPLAY_NAME=Morgan
AVATAR_BACKGROUND_URL=
AVATAR_VIDEO_BITRATE=1200000

# Cassidy-style Microsoft Teams voice escalation via Azure Communication Services
ACS_CONNECTION_STRING=<azure-communication-services-connection-string>
ACS_SOURCE_USER_ID=<optional-preprovisioned-acs-user-id>
ACS_TEAMS_FEDERATION_RESOURCE_ID=<acs-resource-id-used-in-Set-CsTeamsAcsFederationConfiguration>
ACS_REALTIME_VOICE=verse
BASE_URL=https://<morgan-app>.azurewebsites.net
PUBLIC_HOSTNAME=<morgan-app>.azurewebsites.net

# Agentic auth (OBO token flow for MCP servers)
USE_AGENTIC_AUTH=true
agentic_connectionName=AgenticAuthConnection
agentic_altBlueprintConnectionName=service_connection
agentic_scopes=https://graph.microsoft.com/.default
